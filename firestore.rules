rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Locations are readable by everyone
    match /locations/{locationId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email));
    }

    // Config is readable by everyone, writable by admins
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email));
    }

    // Admin users list is only readable/writable by admins
    match /adminUsers/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Only manually via Firebase Console
    }
  }
}
